# ============================================
# .env.example — CodeLens Backend
# Copy this file to .env and fill in values.
# NEVER commit the real .env file.
# ============================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB Connection
# Use MongoDB Atlas URI for production:
# mongodb+srv://<user>:<password>@cluster.mongodb.net/codelens?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/codelens

# JWT Secret — MUST be a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET

# JWT Token Expiry
JWT_EXPIRE=7d

# CORS Allowed Origins — comma-separated list of your frontend domain(s)
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# ---- Email (for forgot-password OTP) ----
# SMTP server settings — example below uses Gmail with App Password
# For Gmail: enable 2FA → Google Account → Security → App Passwords → generate one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM="CodeLens" <your-gmail@gmail.com>

# ============================================
# .gitignore — College Project
# ============================================

# ---- Project-Specific Documentation ----
development.md
Docs/

# ---- Backend Dependencies (Node.js) ----
Backend/node_modules/
package-lock.json
yarn.lock

# ---- Environment Secrets ----
.env
Backend/.env

# ---- User Uploaded Data (Runtime) ----
Backend/Data/Avatar/uploads/*
!Backend/Data/Avatar/uploads/.gitkeep

# ---- Project Scripts ----
push_commits.py
__pycache__/
*.pyc